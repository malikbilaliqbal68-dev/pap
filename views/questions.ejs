    function openPicker(type, customList = null, isSub = false) {
      const list = document.getElementById('pickerList');
      const backBtn = document.getElementById('pickerBackBtn');
      const title = document.getElementById('pickerTitle');
      const addBtn = document.getElementById('pickerAddBtn');
      currentPickerType = type;
      if (['mcqs', 'short', 'long'].includes(type)) {
        addBtn.classList.remove('hidden');
      } else {
        addBtn.classList.add('hidden');
      }

      if (!isSub) {
        pickerHistory = [];
        backBtn.classList.add('hidden');
        title.innerText = `منتخب کریں: ${getSectionLabel(type)}`;
      } else {
        backBtn.classList.remove('hidden');
      }

      const itemsToShow = customList || pools[type];

      list.innerHTML = itemsToShow.map(it => {
        const containsUrdu = (txt) => /[\u0600-\u06FF]/.test(String(txt || ''));
        const isUrduFolder = containsUrdu(it.en);
        if (it.isFolder) {
          return `
              <div class="bg-white border rounded-xl p-4 flex items-center justify-between cursor-pointer hover:bg-gray-50" 
                   onclick="enterFolder('${type}', '${it.en.replace(/'/g, "\\'")}')">
                <div class="flex items-center gap-4">
                    <i class="fa-solid fa-folder text-yellow-500"></i>
                    <span class="${isUrduFolder ? 'urdu-text text-right text-blue-600' : 'font-bold text-gray-700'}">${it.en}</span>
                </div>
                <i class="fa-solid fa-chevron-right text-gray-300"></i>
              </div>`;
        }

        const enText = String(it.en || '').trim();
        const urText = String(it.ur || '').trim();
        const urduFromEn = containsUrdu(enText);
        const urduFromUr = containsUrdu(urText);
        const normalizeCompare = (txt) => String(txt || '').replace(/[\s\-\u0640_.،,:;!?()'"]/g, '').toLowerCase();
        const sameMeaning = normalizeCompare(enText) && normalizeCompare(enText) === normalizeCompare(urText);
        const showAsUrduOnly = urduFromEn && !urText;
        const showOnlyUr = (urduFromEn && urduFromUr) || (urduFromUr && sameMeaning);

        return `
          <div class="bg-white border rounded-xl p-4 flex items-start gap-4 shadow-sm hover:border-green-300 transition">
            <input type="checkbox" class="w-5 h-5 mt-1" 
                   ${sectionState[type].picked.some(p => p.en === it.en) ? 'checked' : ''} 
                   onchange="toggleSelection('${type}', '${it.en.replace(/'/g, "\\'")}', this.checked)">
            <div class="flex-1">
                ${showAsUrduOnly || showOnlyUr ? `<div class="urdu-text text-right text-blue-600 text-sm leading-relaxed break-words">${urText || enText}</div>` : (enText ? `<div class="font-semibold text-gray-800 text-sm leading-relaxed break-words">${enText}</div>` : '')}
                ${(!showAsUrduOnly && !showOnlyUr && it.ur) ? `<div class="urdu-text text-right text-blue-600 text-sm mt-2 leading-relaxed break-words">${it.ur}</div>` : ''}
            </div>
          </div>`;
      }).join('');

      document.getElementById('pickerModal').classList.remove('hidden');
      document.getElementById('pickerModal').classList.add('flex');
    }

